namespace TP1_Ejercicios1
{
    internal class Program

    {
        //Edad aproximada en días Escribe un programa que solicite al usuario ingresar su edad en años y calcule aproximadamente
        //cuántos días ha vivido (considerando 365 días por año)
        //variables = edad
        static void Main(string[] args)
        {
            int edad;
            


            Console.WriteLine("Ingrese su edad ");
            edad = Convert.ToInt32(Console.ReadLine());
   

            //formula , multiplicacion de las dos variables 

            double diasvividos = edad * 365;

            

            Console.WriteLine(" Has vidido  : " + diasvividos + "dias");

        }
    }
}
