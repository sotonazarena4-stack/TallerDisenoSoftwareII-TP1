namespace TP1_Ejercicios1
{
    internal class Program

    {
        //Escribe un programa que solicite al usuario ingresar el largo y
        //el ancho de un terreno rectangular
        //variables = largo del terrno y ancho del terreno
        static void Main(string[] args)
        {
            double largo;
            double ancho;


            Console.WriteLine("Ingrese el largo del terreno");
            largo = Convert.ToDouble(Console.ReadLine());
            Console.WriteLine("Ingrese el ancho del terreno");
            ancho = Convert.ToDouble(Console.ReadLine());

            //nota : la formula del perimetro es, perimetro = 2 x (largo y ancho)

            double perimetro = 2 * (largo + ancho);

            Console.WriteLine("El perimetro del terreno es : " + perimetro);

        }
    }
}
